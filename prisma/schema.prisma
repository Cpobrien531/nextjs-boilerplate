generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  userId             Int       @id @default(autoincrement()) @map("user_id")
  fullName           String    @map("full_name") @db.VarChar(150)
  email              String    @unique @db.VarChar(255)
  accountCreatedDate DateTime  @default(dbgenerated("(curdate())")) @map("account_created_date") @db.Date
  dateRetentionYears Int       @default(7) @map("date_retention_years") @db.TinyInt
  password           String    @db.VarChar(255)
  budgets            Budget[]
  expenses           Expense[]
  exports            Export[]
  tags               Tag[]

  @@map("user")
}

model Category {
  categoryId          Int             @id @default(autoincrement()) @map("category_id")
  categoryName        String          @unique @map("category_name") @db.VarChar(100)
  categoryDescription String?         @map("category_description") @db.Text
  budgets             Budget[]
  expenses            Expense[]
  spendingCharts      SpendingChart[]

  @@map("category")
}

model Expense {
  expenseId             Int          @id @default(autoincrement()) @map("expense_id")
  userId                Int          @map("user_id")
  expenseDate           DateTime     @map("expense_date") @db.Date
  amount                Decimal      @db.Decimal(12, 2)
  vendorName            String       @map("vendor_name") @db.VarChar(200)
  description           String?      @db.Text
  categoryId            Int          @map("category_id")
  isBillable            Boolean      @default(false) @map("is_billable")
  createdTimestamp      DateTime     @default(now()) @map("created_timestamp") @db.Timestamp(0)
  lastModifiedTimestamp DateTime     @default(now()) @updatedAt @map("last_modified_timestamp") @db.Timestamp(0)
  category              Category     @relation(fields: [categoryId], references: [categoryId])
  user                  User         @relation(fields: [userId], references: [userId])
  tags                  ExpenseTag[]
  receipts              Receipt[]

  @@index([categoryId], map: "expense_category_id_fkey")
  @@index([userId], map: "expense_user_id_fkey")
  @@map("expense")
}

model Receipt {
  receiptId       Int      @id @default(autoincrement()) @map("receipt_id")
  expenseId       Int      @map("expense_id")
  imagePath       String   @map("image_path") @db.VarChar(500)
  uploadDate      DateTime @default(dbgenerated("(curdate())")) @map("upload_date") @db.Date
  extractedAmount Decimal? @map("extracted_amount") @db.Decimal(12, 2)
  extractedVendor String?  @map("extracted_vendor") @db.VarChar(200)
  expense         Expense  @relation(fields: [expenseId], references: [expenseId])

  @@index([expenseId], map: "receipt_expense_id_fkey")
  @@map("receipt")
}

model Tag {
  tagId    Int          @id @default(autoincrement()) @map("tag_id")
  userId   Int          @map("user_id")
  tagName  String       @map("tag_name") @db.VarChar(100)
  tagType  String       @map("tag_type") @db.VarChar(50)
  expenses ExpenseTag[]
  user     User         @relation(fields: [userId], references: [userId])

  @@index([userId], map: "tag_user_id_fkey")
  @@map("tag")
}

model ExpenseTag {
  expenseId Int     @map("expense_id")
  tagId     Int     @map("tag_id")
  expense   Expense @relation(fields: [expenseId], references: [expenseId])
  tag       Tag     @relation(fields: [tagId], references: [tagId])

  @@id([expenseId, tagId])
  @@index([tagId], map: "expense_tag_tag_id_fkey")
  @@map("expense_tag")
}

model Budget {
  budgetId     Int           @id @default(autoincrement()) @map("budget_id")
  userId       Int           @map("user_id")
  categoryId   Int           @map("category_id")
  month        Int           @db.TinyInt
  year         Int           @db.SmallInt
  budgetAmount Decimal       @map("budget_amount") @db.Decimal(12, 2)
  category     Category      @relation(fields: [categoryId], references: [categoryId])
  user         User          @relation(fields: [userId], references: [userId])
  alerts       BudgetAlert[]

  @@unique([userId, categoryId, month, year])
  @@index([categoryId], map: "budget_category_id_fkey")
  @@map("budget")
}

model BudgetAlert {
  alertId        Int      @id @default(autoincrement()) @map("alert_id")
  budgetId       Int      @map("budget_id")
  alertThreshold Decimal  @map("alert_threshold") @db.Decimal(5, 2)
  alertDate      DateTime @default(dbgenerated("(curdate())")) @map("alert_date") @db.Date
  budget         Budget   @relation(fields: [budgetId], references: [budgetId])

  @@index([budgetId], map: "budget_alert_budget_id_fkey")
  @@map("budget_alert")
}

model Export {
  exportId        Int      @id @default(autoincrement()) @map("export_id")
  userId          Int      @map("user_id")
  exportFormat    String   @map("export_format") @db.VarChar(20)
  startDate       DateTime @map("start_date") @db.Date
  endDate         DateTime @map("end_date") @db.Date
  exportTimestamp DateTime @default(now()) @map("export_timestamp") @db.Timestamp(0)
  user            User     @relation(fields: [userId], references: [userId])

  @@index([userId], map: "export_user_id_fkey")
  @@map("export")
}

model SpendingChart {
  chartId    Int      @id @default(autoincrement()) @map("chart_id")
  categoryId Int      @map("category_id")
  timePeriod String   @map("time_period") @db.VarChar(20)
  totalSpent Decimal  @default(0.00) @map("total_spent") @db.Decimal(14, 2)
  category   Category @relation(fields: [categoryId], references: [categoryId])

  @@unique([categoryId, timePeriod])
  @@map("spending_chart")
}
