// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  userId             Int      @id @default(autoincrement()) @map("user_id")
  fullName           String   @map("full_name")
  email              String   @unique
  accountCreatedDate DateTime @default(now()) @map("account_created_date")
  dateRetentionYears Int      @default(7) @map("date_retention_years")
  password           String

  expenses Expense[]
  tags     Tag[]
  budgets  Budget[]
  exports  Export[]

  @@map("user")
}

model Category {
  categoryId          Int     @id @default(autoincrement()) @map("category_id")
  categoryName        String  @unique @map("category_name")
  categoryDescription String? @map("category_description")

  expenses       Expense[]
  budgets        Budget[]
  spendingCharts SpendingChart[]

  @@map("category")
}

model Expense {
  expenseId             Int      @id @default(autoincrement()) @map("expense_id")
  userId                Int      @map("user_id")
  user                  User     @relation(fields: [userId], references: [userId])
  expenseDate           DateTime @map("expense_date")
  amount                Decimal  @default(0) 
  vendorName            String   @map("vendor_name")
  description           String?
  categoryId            Int      @map("category_id")
  category              Category @relation(fields: [categoryId], references: [categoryId])
  isBillable            Boolean  @default(false) @map("is_billable")
  createdTimestamp      DateTime @default(now()) @map("created_timestamp")
  lastModifiedTimestamp DateTime @default(now()) @updatedAt @map("last_modified_timestamp")

  receipts Receipt[]
  tags     ExpenseTag[]

  @@map("expense")
}

model Receipt {
  receiptId       Int      @id @default(autoincrement()) @map("receipt_id")
  expenseId       Int      @map("expense_id")
  expense         Expense  @relation(fields: [expenseId], references: [expenseId])
  imagePath       String   @map("image_path")
  uploadDate      DateTime @default(now()) @map("upload_date")
  extractedAmount Decimal? @map("extracted_amount")
  extractedVendor String?  @map("extracted_vendor")

  @@map("receipt")
}

model Tag {
  tagId    Int        @id @default(autoincrement()) @map("tag_id")
  userId   Int        @map("user_id")
  user     User       @relation(fields: [userId], references: [userId])
  tagName  String     @map("tag_name")
  tagType  String     @map("tag_type")

  expenses ExpenseTag[]

  @@map("tag")
}

model ExpenseTag {
  expenseId Int     @map("expense_id")
  expense   Expense @relation(fields: [expenseId], references: [expenseId])
  tagId     Int     @map("tag_id")
  tag       Tag     @relation(fields: [tagId], references: [tagId])

  @@id([expenseId, tagId])
  @@map("expense_tag")
}

model Budget {
  budgetId     Int      @id @default(autoincrement()) @map("budget_id")
  userId       Int      @map("user_id")
  user         User     @relation(fields: [userId], references: [userId])
  categoryId   Int      @map("category_id")
  category     Category @relation(fields: [categoryId], references: [categoryId])
  month        Int
  year         Int
  budgetAmount Decimal  @default(0) @map("budget_amount")

  alerts BudgetAlert[]

  @@unique([userId, categoryId, month, year])
  @@map("budget")
}

model BudgetAlert {
  alertId        Int      @id @default(autoincrement()) @map("alert_id")
  budgetId       Int      @map("budget_id")
  budget         Budget   @relation(fields: [budgetId], references: [budgetId])
  alertThreshold Decimal  @default(0) @map("alert_threshold")
  alertDate      DateTime @default(now()) @map("alert_date")

  @@map("budget_alert")
}

model Export {
  exportId        Int      @id @default(autoincrement()) @map("export_id")
  userId          Int      @map("user_id")
  user            User     @relation(fields: [userId], references: [userId])
  exportFormat    String   @map("export_format")
  startDate       DateTime @map("start_date")
  endDate         DateTime @map("end_date")
  exportTimestamp DateTime @default(now()) @map("export_timestamp")

  @@map("export")
}

model SpendingChart {
  chartId    Int      @id @default(autoincrement()) @map("chart_id")
  categoryId Int      @map("category_id")
  category   Category @relation(fields: [categoryId], references: [categoryId])
  timePeriod String   @map("time_period")
  totalSpent Decimal  @default(0.00) @map("total_spent")

  @@unique([categoryId, timePeriod])
  @@map("spending_chart")
}
